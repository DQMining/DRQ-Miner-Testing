# Copy to .env.operator and fill private values.
# This file is safe to commit; .env.operator is gitignored.

# Optional override for miner donate endpoint (defaults in code):
DRQ_DONATE_PROXY_HOST=www.dqmining.com
DRQ_DONATE_PROXY_PORT=3333

# Proxy host operations
DRQ_PROXY_SSH_USER=dq111
DRQ_PROXY_SSH_HOST=REPLACE_ME
DRQ_PROXY_SSH_PORT=22

# Dev wallet placeholders (replace in local .env.operator only)
DRQ_DEV_WALLET_RX0=REPLACE_ME
DRQ_DEV_WALLET_GHOSTRIDER=REPLACE_ME
DRQ_DEV_WALLET_VERUS=REPLACE_ME
DRQ_DEV_WALLET_DERO=REPLACE_ME
DRQ_DEV_WALLET_BC3=REPLACE_ME
DRQ_DEV_WALLET_SHA256T=REPLACE_ME
DRQ_DEV_WALLET_JANUSHASH=REPLACE_ME
DRQ_DEV_WALLET_PEARL=REPLACE_ME

# Optional private GitHub source for proxy pulls
DRQ_PRIVATE_REPO_URL=REPLACE_ME
