+    int regs[4];
+    __cpuid(regs, static_cast<int>(leaf));
+    *eax = static_cast<unsigned int>(regs[0]);
+    *ebx = static_cast<unsigned int>(regs[1]);
+    *ecx = static_cast<unsigned int>(regs[2]);
